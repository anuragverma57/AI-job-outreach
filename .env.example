# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=outreach
POSTGRES_PASSWORD=outreach_secret
POSTGRES_DB=outreach

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API Gateway
API_PORT=8080
JWT_SECRET=your-jwt-secret-change-in-production
CORS_ORIGINS=http://localhost:3000

# AI Service (FastAPI — what api-gateway calls)
AI_SERVICE_URL=http://localhost:8000

# LLM: OpenAI-compatible API ONLY (e.g. Ollama OpenAI shim on another PC).
# Do NOT set this to the same host:port as ai-service — that would call the wrong app.
# Full chat URL = LLM_BASE_URL + /chat/completions
LLM_BASE_URL=
# Must match a model name your LLM server actually serves (test with curl to /v1/chat/completions).
LLM_MODEL=
# Optional — leave empty for local Ollama
LLM_API_KEY=
# When true, ai-service uses POST .../chat/completions with "stream": true (SSE) for internal calls;
# on failure it falls back to non-stream once where implemented (see docs/IMPLEMENTATION-GUIDE-LLM-STREAMING.md).
LLM_STREAM=false
# httpx timeouts (seconds). Read timeout is large for slow remote LLM + SSE.
LLM_HTTP_CONNECT_TIMEOUT=10
LLM_HTTP_READ_TIMEOUT=600
LLM_HTTP_WRITE_TIMEOUT=30
LLM_HTTP_POOL_TIMEOUT=5
# Max wall-clock for one stream (seconds); 0 = disabled (read timeout still applies).
LLM_STREAM_MAX_SECONDS=900

# Worker / Email Sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
